# ── Test 1: Linear graph (Distance-Time) ─────────────────
create graph "Distance Time":
    x axis be "Time".
    y axis be "Distance".
    range x is 0 to 10.
    range y is 0 to 50.
    type be linear.
    color be blue.
    points are (0,0) (2,10) (4,20) (6,30) (8,40) (10,50).
end.

# ── Test 2: Exponential growth ───────────────────────────
create graph "Population Growth":
    x axis be "Year".
    y axis be "Population".
    range x is 0 to 5.
    range y is 0 to 300.
    type be exponential.
    color be green.
    points are (0,1) (1,3) (2,9) (3,27) (4,81) (5,243).
end.

# ── Test 3: Bar chart ────────────────────────────────────
create graph "Student Scores":
    x axis be "Student".
    y axis be "Score".
    range x is 0 to 6.
    range y is 0 to 100.
    type be bar.
    color be purple.
    points are (1,85) (2,92) (3,78) (4,96) (5,88) (6,73).
end.

# ── Test 4: Scatter plot ─────────────────────────────────
create graph "Random Data":
    x axis be "X".
    y axis be "Y".
    range x is 0 to 10.
    range y is 0 to 10.
    type be scatter.
    color be orange.
    points are (1,3) (3,7) (5,2) (7,8) (9,4) (2,6) (8,1).
end.

show "All graphs created!".
