# import_test.nat — NAT v3.5 p2 Official Tree Import Tests

# ── Test 1: math.tree ────────────────────────────────────
show "Test 1: math.tree".
use math.tree.
show PI.
show sqrt(144).
show factorial(5).
show gcd(12, 8).
show is_prime(13).
show sin_deg(90).
show cos_deg(0).
show tan_deg(45).
show dec_to_bin(25).
show dec_to_hex(255).
show dec_to_roman(2024).
show percent_to_dec(45).

# ── Test 2: geometry.tree ────────────────────────────────
show "Test 2: geometry.tree".
use geometry.tree.
show area_square(5).
show area_circle(5).
show volume_sphere(3).
show distance(0, 0, 3, 4).
show area_triangle_heron(3, 4, 5).
show magnitude(3, 4).
show interior_angle(6).

# ── Test 3: convert.tree ─────────────────────────────────
show "Test 3: convert.tree".
use convert.tree.
show km_to_mile(10).
show cel_to_fahr(100).
show kg_to_lbs(70).
show bytes_to_kb(1024).
show sec_to_ms(60).

# ── Test 4: string.tree ──────────────────────────────────
show "Test 4: string.tree".
use string.tree.
show starts_with("Nisarg", "Nis").
show ends_with("Nisarg", "arg").
show is_alpha("Hello").
show is_numeric("123").
show count_of("a", "banana").
show index_of("o", "Hello World").
show word_count("Hello World NAT").
show title_of("hello world from nat").
show pad_left("hi", 6, "*").

# ── Test 5: missing tree error ───────────────────────────
show "Test 5: missing tree".
use missing.tree.
show "code continues after error".
